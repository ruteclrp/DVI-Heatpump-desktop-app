{
  "name": "dvi-heatpump-desktop-app",
  "version": "0.3.3",
  "private": true,
  "description": "Windows desktop shell for the DVI Heatpump app",
  "type": "module",
  "main": "dist/main/main.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --arm64",
    "dist:win:x64": "npm run build && electron-builder --win nsis --x64",
    "dist:win:arm64": "npm run build && electron-builder --win nsis --arm64"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@swc/core": "^1.11.9",
    "@types/node": "^22.13.14",
    "electron": "^35.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.dvi.heatpump.desktop",
    "productName": "DVI Heatpump",
    "artifactName": "${productName} Setup ${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
